# Development image: builds tee-streams natively for the host platform and
# runs it directly in a minimal container.  Works on Apple Silicon and x86_64.
#
# For real SGX deployment use Dockerfile.gramine (requires x86_64 Linux host)
# and adapt it to build tee-streams with --features sgx -p tee-streams.
FROM rust:slim AS builder

WORKDIR /build
COPY . .

RUN cargo build --release -p tee-streams

# ─── Runtime ─────────────────────────────────────────────────────────────────
FROM debian:bookworm-slim

RUN apt-get update -qq \
 && apt-get install -y --no-install-recommends ca-certificates \
 && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/tee-streams /app/tee-streams

ENTRYPOINT ["/app/tee-streams"]
CMD ["--nickname", "node", "--room", "tee-streams-lobby"]
